# Скопіюйте у .env і заповніть. Python-сервіси читають файл напряму.
# ⚠️ .env містить секрет — не комітити, не пересилати.
HF_TOKEN=hf_...
OLLAMA_MODEL=qwen3.6:27b-q4_K_M
OLLAMA_URL=http://localhost:11434
OLLAMA_NUM_CTX=16384
OLLAMA_THINK=false
ROTATE_DAYS=14
RECORD_AEC=false             # fallback лише для прямого record.py без --raw/--aec
MLX_MODEL=mlx-community/whisper-large-v3-mlx
TRANSCRIBE_LANGUAGE=uk       # uk | auto
DIARIZE_DEVICE=auto          # auto = MPS з автоматичним fallback на CPU
DEDUP_MIC=true               # для AEC автоматично вимикається
MIN_SESSION_SECONDS=10       # коротші записи не відправляються в ASR/LLM
SILENT_RECORDING_PEAK_DBFS=-70 # обидві доріжки нижче порога → не запускати ASR/LLM
MAX_AUTO_RETRIES=3
ALLOW_REMOTE_OLLAMA=false    # захист від випадкового витоку транскрипту
MAX_RECORD_SECONDS=21600     # 6 год
SILENCE_POPUP=true           # запропонувати stop, якщо обидві доріжки тихі
SILENCE_SECONDS=90
SILENCE_MIN_RECORD_SECONDS=120
SILENCE_REPEAT_SECONDS=600
SILENCE_DIALOG_TIMEOUT=30
MIC_ACTIVITY_DBFS=-42
SYSTEM_ACTIVITY_DBFS=-50
